# Database (PostgreSQL)
DATABASE_URL="postgresql://ebts_user:your_password@localhost:5432/ebts_db"

# JWT Secret
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Emergency Box System <your-email@gmail.com>"

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Notification Settings (days before expiry to alert)
ALERT_DAYS_30=30
ALERT_DAYS_7=7
ALERT_DAYS_1=1

# App URL (for QR code generation)
APP_URL=http://localhost:5173
