# PostgreSQL Password
POSTGRES_PASSWORD=YourStrongPassword123!

# JWT Secret (random 64 chars)
JWT_SECRET=your-random-64-char-secret-here

# Frontend URL (your domain or Oracle IP)
FRONTEND_URL=http://YOUR_ORACLE_IP
APP_URL=http://YOUR_ORACLE_IP

# Email (Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-pharmacy@gmail.com
SMTP_PASS=your-app-specific-password
EMAIL_FROM="Emergency Box System <your-pharmacy@gmail.com>"

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
